# Jupyter Notebook для экспериментов

import sys
sys.path.append('..')

import json
import time
import pandas as pd
import matplotlib.pyplot as plt
from ml.models.baseline import LLavaBaselineModel
from backend.utils.image_utils import load_test_images
import seaborn as sns

# 1. Инициализация модели
model = LLavaBaselineModel()

# 2. Проверка доступности
print("Проверка Ollama...")
if model.check_ollama_health():
    print("✅ Ollama доступен, модель загружена")
else:
    print("❌ Ollama недоступен или модель не загружена")
    print("Запустите: ollama pull llava:13b")

# 3. Загрузка тестовых данных
test_cases = [
    {
        "id": 1,
        "clean": "../static/test_images/clear_flat_1.jpg",
        "dirty": "../static/test_images/dirty_flat_1.jpg",
        "expected_score": 6,
        "expected_defects": ["пыль на столе", "разбросанные вещи"]
    },
    {
        "id": 2,
        "clean": "../static/test_images/clear_flat_2.jpg",
        "dirty": "../static/test_images/dirty_flat_2.jpg",
        "expected_score": 3,
        "expected_defects": ["грязная посуда", "мусор на полу", "беспорядок"]
    },
    # Добавьте больше тестовых случаев
]

# 4. Запуск экспериментов
results = []
for test_case in test_cases:
    print(f"\nТест #{test_case['id']}")
    print(f"Чистое: {test_case['clean']}")
    print(f"Грязное: {test_case['dirty']}")
    
    try:
        start_time = time.time()
        result = model.analyze_cleanliness(
            test_case["clean"],
            test_case["dirty"]
        )
        latency = time.time() - start_time
        
        # Сохраняем результаты
        test_result = {
            "test_id": test_case["id"],
            "latency": latency,
            "token_count": result["metrics"]["token_count"],
            "predicted_score": result["parsed_response"]["score"],
            "expected_score": test_case["expected_score"],
            "defects_count": len(result["parsed_response"]["defects"]),
            "expected_defects_count": len(test_case["expected_defects"]),
            "success": result["success"],
            "model_response": result["raw_response"][:200] + "..." if len(result["raw_response"]) > 200 else result["raw_response"]
        }
        
        results.append(test_result)
        
        print(f"✅ Успешно")
        print(f"   Оценка: {result['parsed_response']['score']}/10 (ожидалось: {test_case['expected_score']})")
        print(f"   Недостатков найдено: {len(result['parsed_response']['defects'])}")
        print(f"   Время: {latency:.2f}с, Токены: {result['metrics']['token_count']}")
        
    except Exception as e:
        print(f"❌ Ошибка: {e}")
        results.append({
            "test_id": test_case["id"],
            "error": str(e),
            "success": False
        })

# 5. Анализ результатов
df = pd.DataFrame(results)

print("\n" + "="*50)
print("СВОДКА ЭКСПЕРИМЕНТОВ")
print("="*50)

if len(df) > 0:
    # Основные метрики
    success_rate = df[df["success"] == True].shape[0] / len(df) * 100
    avg_latency = df["latency"].mean() if "latency" in df.columns else 0
    avg_tokens = df["token_count"].mean() if "token_count" in df.columns else 0
    
    print(f"Успешных тестов: {success_rate:.1f}%")
    print(f"Среднее время ответа: {avg_latency:.2f}с")
    print(f"Среднее количество токенов: {avg_tokens:.0f}")
    
    # Визуализация
    fig, axes = plt.subplots(2, 2, figsize=(12, 10))
    
    # 1. Распределение времени ответа
    if "latency" in df.columns:
        axes[0, 0].hist(df["latency"].dropna(), bins=10, alpha=0.7)
        axes[0, 0].set_title("Распределение времени ответа")
        axes[0, 0].set_xlabel("Время (секунды)")
        axes[0, 0].set_ylabel("Частота")
    
    # 2. Количество токенов
    if "token_count" in df.columns:
        axes[0, 1].hist(df["token_count"].dropna(), bins=10, alpha=0.7, color='green')
        axes[0, 1].set_title("Распределение количества токенов")
        axes[0, 1].set_xlabel("Токены")
        axes[0, 1].set_ylabel("Частота")
    
    # 3. Оценки модели
    if all(col in df.columns for col in ["predicted_score", "expected_score"]):
        axes[1, 0].scatter(df["expected_score"], df["predicted_score"], alpha=0.7)
        axes[1, 0].plot([0, 10], [0, 10], 'r--', alpha=0.5)
        axes[1, 0].set_title("Предсказанные vs Ожидаемые оценки")
        axes[1, 0].set_xlabel("Ожидаемая оценка")
        axes[1, 0].set_ylabel("Предсказанная оценка")
        axes[1, 0].set_xlim(0, 10)
        axes[1, 0].set_ylim(0, 10)
    
    # 4. Количество недостатков
    if "defects_count" in df.columns:
        axes[1, 1].bar(range(len(df)), df["defects_count"].fillna(0))
        axes[1, 1].set_title("Количество найденных недостатков")
        axes[1, 1].set_xlabel("Тест")
        axes[1, 1].set_ylabel("Количество недостатков")
    
    plt.tight_layout()
    plt.savefig("../results/experiment_summary.png", dpi=150)
    plt.show()
    
    # Сохраняем детальные результаты
    df.to_csv("../results/experiment_results.csv", index=False)
    print(f"\nРезультаты сохранены в results/experiment_results.csv")
    
    # Примеры ответов модели
    print("\n" + "="*50)
    print("ПРИМЕРЫ ОТВЕТОВ МОДЕЛИ")
    print("="*50)
    
    for idx, row in df.iterrows():
        if "model_response" in row and pd.notna(row["model_response"]):
            print(f"\nТест #{row['test_id']}:")
            print(row["model_response"])
            print("-" * 50)

# 6. Стресс-тест
print("\n" + "="*50)
print("СТРЕСС-ТЕСТ (10 последовательных запросов)")
print("="*50)

stress_results = []
for i in range(10):
    try:
        start_time = time.time()
        result = model.analyze_cleanliness(
            test_cases[0]["clean"],
            test_cases[0]["dirty"]
        )
        latency = time.time() - start_time
        
        stress_results.append({
            "request": i + 1,
            "latency": latency,
            "tokens": result["metrics"]["token_count"],
            "success": True
        })
        print(f"Запрос {i+1}: {latency:.2f}с")
        
    except Exception as e:
        stress_results.append({
            "request": i + 1,
            "latency": 0,
            "success": False,
            "error": str(e)
        })
        print(f"Запрос {i+1}: ❌ Ошибка")

stress_df = pd.DataFrame(stress_results)
if len(stress_df) > 0:
    print(f"\nСреднее время: {stress_df['latency'].mean():.2f}с")
    print(f"Мин: {stress_df['latency'].min():.2f}с, Макс: {stress_df['latency'].max():.2f}с")
    print(f"Успешных: {stress_df['success'].sum()}/{len(stress_df)}")