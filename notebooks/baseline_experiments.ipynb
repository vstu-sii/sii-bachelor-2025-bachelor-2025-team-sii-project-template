import time
from pprint import pprint

from ml.models.baseline import generate_deck_with_stats
from ml.prompt_templates import PitchDeckPromptConfig

test_cases = [
    {
        "id": "t1",
        "name": "GreenFleet",
        "brief": "GreenFleet is a B2B SaaS platform that helps last-mile logistics companies reduce fuel costs and CO2 emissions by optimizing routes for electric vans and mixed fleets.",
        "config": PitchDeckPromptConfig(
            target_slide_count=10,
            tone="formal",
            audience="early-stage VC",
            language="en",
        ),
    },
    {
        "id": "t2",
        "name": "MedAI Triage",
        "brief": "MedAI Triage is an AI assistant for small clinics that helps nurses perform faster and more consistent triage by asking structured questions and suggesting risk level.",
        "config": PitchDeckPromptConfig(
            target_slide_count=11,
            tone="formal",
            audience="healthtech VC",
            language="en",
        ),
    },
    {
        "id": "t3",
        "name": "SubSync",
        "brief": "SubSync is a SaaS platform for SMBs that tracks all recurring subscriptions in one place, flags duplicates and negotiates better pricing using aggregated benchmarks.",
        "config": PitchDeckPromptConfig(
            target_slide_count=10,
            tone="storytelling",
            audience="B2B SaaS investor",
            language="en",
        ),
    },
    {
        "id": "t4",
        "name": "EduPilot",
        "brief": "EduPilot is an AI copilot for teachers that creates lesson plans, quizzes and homework based on curriculum standards.",
        "config": PitchDeckPromptConfig(
            target_slide_count=9,
            tone="formal",
            audience="edtech VC",
            language="en",
        ),
    },
    {
        "id": "t5",
        "name": "FarmSense",
        "brief": "FarmSense is an IoT + AI platform that helps small farmers monitor soil, irrigation and crop health via low-cost sensors.",
        "config": PitchDeckPromptConfig(
            target_slide_count=10,
            tone="formal",
            audience="impact investor",
            language="en",
        ),
    },
]

results = []

for case in test_cases:
    print(f"=== {case['id']} | {case['name']} ===")
    start = time.perf_counter()
    deck, stats = generate_deck_with_stats(case["brief"], case["config"])
    wall_time_ms = (time.perf_counter() - start) * 1000.0

    slide_count = len(deck["slides"])
    print(f"Slides: {slide_count}")
    print(f"Latency (LLM): {stats['latency_ms']:.1f} ms")
    print(f"Latency (wall): {wall_time_ms:.1f} ms")
    print(f"Tokens (prompt): {stats['prompt_tokens']}")
    print(f"Tokens (completion): {stats['completion_tokens']}")
    print(f"Tokens (total): {stats['total_tokens']}")
    print()

    results.append(
        {
            "id": case["id"],
            "name": case["name"],
            "slide_count": slide_count,
            "latency_ms": stats["latency_ms"],
            "wall_time_ms": wall_time_ms,
            "prompt_tokens": stats["prompt_tokens"],
            "completion_tokens": stats["completion_tokens"],
            "total_tokens": stats["total_tokens"],
        }
    )

def avg(values):
    return sum(values) / len(values) if values else 0.0


avg_latency = avg([r["latency_ms"] for r in results])
avg_wall = avg([r["wall_time_ms"] for r in results])
avg_prompt_tokens = avg([r["prompt_tokens"] for r in results])
avg_completion_tokens = avg([r["completion_tokens"] for r in results])
avg_total_tokens = avg([r["total_tokens"] for r in results])

print("=== Averages ===")
print(f"Latency (LLM) avg: {avg_latency:.1f} ms")
print(f"Latency (wall) avg: {avg_wall:.1f} ms")
print(f"Prompt tokens avg: {avg_prompt_tokens:.1f}")
print(f"Completion tokens avg: {avg_completion_tokens:.1f}")
print(f"Total tokens avg: {avg_total_tokens:.1f}")

print("\n=== Raw results ===")
pprint(results)
